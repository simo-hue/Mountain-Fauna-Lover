# Public canonical URL used for metadata and structured data.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional. Leave empty to disable Google Analytics.
NEXT_PUBLIC_GA_ID=

# Required for live collaboration email delivery.
# Get a free API key at https://resend.com
RESEND_API_KEY=
# Without a verified domain, use onboarding@resend.dev as the sender.
# With a verified domain, use: Your Name <contact@yourdomain.com>
CONTACT_FROM_EMAIL=onboarding@resend.dev
# Must match your Resend account email when no custom domain is verified.
CONTACT_TO_EMAIL=deerfaunalover@gmail.com
